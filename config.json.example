  "requireApproval": true,
  "notifications": {
    "email": {
      "enabled": true,
      "from": "your-email@gmail.com",
      "appPassword": "your-gmail-app-password",
      "to": ["your-email@gmail.com", "your-phone@vtext.com"]
    }
  },
  "authEnabled": false,
  "password": "changeme",
  "cameras": [
    {
      "id": "cam1",
      "name": "Coop Camera",
      "streamUrl": "http://localhost:8554/cam1/index.m3u8",
      "enabled": true
    },
    {
      "id": "cam2",
      "name": "Yard Camera",
