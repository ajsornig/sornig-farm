{
  "port": 3000,
  "requireApproval": true,
  "cameras": [
    {
      "id": "cam1",
      "name": "Chicken Run",
      "streamUrl": "/hls/stream.m3u8",
      "enabled": true
    },
    {
      "id": "cam2",
      "name": "Chicken Coop",
      "streamUrl": "/hls2/stream.m3u8",
      "enabled": true
    },
    {
      "id": "cam3",
      "name": "Chick Cam",
      "streamUrl": "/hls3/stream.m3u8",
      "enabled": true
    }
  ],
  "recording": {
    "enabled": false,
    "retentionDays": 7
  },
  "chat": {
    "maxMessages": 100,
    "rateLimit": {
      "messages": 5,
      "windowSeconds": 10
    }
  }
}
